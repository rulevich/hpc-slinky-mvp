apiVersion: v1
kind: Pod
metadata:
  name: {{ pod_name }}
  namespace: {{ validation_namespace }}
spec:
  restartPolicy: Never
  containers:
    - name: busybox
      image: busybox:1.36
      command: ["sh", "-c", "sleep 3600"]
      volumeMounts:
        - name: storage
          mountPath: /data
  volumes:
    - name: storage
      persistentVolumeClaim:
        claimName: {{ pvc_name }}
